--// Fungsi Global buat Efek Klik (Anti Bug/Stuck)
local function applyClickEffect(button, normalSize, shrinkSize)
    button.AnchorPoint = Vector2.new(0.5, 0.5)
    
    local function shrink()
        TweenService:Create(button, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = shrinkSize}):Play()
    end
    
    local function restore()
        TweenService:Create(button, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = normalSize}):Play()
    end

    button.MouseButton1Down:Connect(shrink)
    button.MouseButton1Up:Connect(restore)
    button.MouseLeave:Connect(restore) 
end

