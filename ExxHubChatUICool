        end
    end

    -- Fix Main Inventory Frame
    local invCorner = Backpack.Inventory:FindFirstChild("Round") or Instance.new("UICorner")
    invCorner.Name = "Round"
    invCorner.CornerRadius = UDim.new(0, 15)
    invCorner.Parent = Backpack.Inventory
end)
