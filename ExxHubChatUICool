local SearchFrame = Inventory:WaitForChild("Search")
local SearchBox = SearchFrame:WaitForChild("TextBox")
local ClearButton = SearchFrame:WaitForChild("X")

-- Fungsi Utama Style (Bentuk & Warna)
local function ApplyStyle(obj, radius, forceBlack)
    if obj and obj:IsA("GuiObject") then
        obj.BorderSizePixel = 0
        
        -- Paksa warna hitam jika diminta
        if forceBlack then
            obj.BackgroundColor3 = Color3.new(0, 0, 0)
            obj:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
                obj.BackgroundColor3 = Color3.new(0, 0, 0)
            end)
        end

        local corner = obj:FindFirstChild("RoundEffect") or Instance.new("UICorner")
        corner.Name = "RoundEffect"
        corner.CornerRadius = radius or UDim.new(1, 0)
        corner.Parent = obj
    end
end

-- Fungsi khusus untuk menangani elemen internal slot (Equipped & Drag Outline)
local function StyleInternalSlot(slot, isHotbar)
    -- 1. Tangani elemen "Equipped" (biru-biru) yang kamu maksud
    local equipped = slot:FindFirstChild("Equipped")
    if equipped then
        -- Mencari anak ke-4 secara spesifik seperti yang kamu minta
        local children = equipped:GetChildren()
        if children[4] and children[4]:IsA("GuiObject") then
            ApplyStyle(children[4], UDim.new(1, 0))
        end
        -- Opsional: bulatkan semua anak di equipped agar tidak ada yang bocor kotak
        for _, child in pairs(children) do
            if child:IsA("GuiObject") then ApplyStyle(child, UDim.new(1, 0)) end
        end
    end

    -- 2. Tangani Drag/Selection Outline (garis putih saat ditekan/tarik)
    for _, child in pairs(slot:GetChildren()) do
        if child.Name:lower():find("outline") or child.Name:lower():find("selection") then
            ApplyStyle(child, UDim.new(1, 0))
        end
    end
    
    -- Pastikan slot utama tetap bulat dan hitam (untuk hotbar)
    ApplyStyle(slot, UDim.new(1, 0), isHotbar)
end

