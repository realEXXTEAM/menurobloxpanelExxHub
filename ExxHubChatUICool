-- 4. Looping Slot 1 - 99 (Hotbar & Inventory)
local function RefreshAllSlots()
    for i = 1, 99 do
        local id = tostring(i)
        
        -- Hotbar
        local hSlot = Hotbar:FindFirstChild(id)
        if hSlot then 
            StyleInternalSlot(hSlot, true) 
        end
        
        -- Inventory
        local iSlot = InvGrid:FindFirstChild(id)
        if iSlot then 
            StyleInternalSlot(iSlot, false) 
        end
    end
end

-- Eksekusi awal dan jaga agar tetap bulat saat UI berubah
RefreshAllSlots()
Hotbar.ChildAdded:Connect(function(child) StyleInternalSlot(child, true) end)
InvGrid.ChildAdded:Connect(function(child) StyleInternalSlot(child, false) end)

