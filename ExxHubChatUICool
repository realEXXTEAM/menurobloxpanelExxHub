--- HOTBAR + INVENTORY
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local Backpack = CoreGui:WaitForChild("RobloxGui"):WaitForChild("Backpack")
local Hotbar = Backpack:WaitForChild("Hotbar")
local InvGrid = Backpack:WaitForChild("Inventory"):WaitForChild("ScrollingFrame"):WaitForChild("UIGridFrame")
local SearchBox = Backpack.Inventory.Search.TextBox

-- Fungsi Brutal untuk ganti Edge bawaan ke Child [4] yang bulat
local function FixSelectionEdge(slot, isHotbar)
    if not slot then return end

    -- 1. Slot Utama: Harus Bulat
    local slotCorner = slot:FindFirstChild("SlotRound") or Instance.new("UICorner")
    slotCorner.Name = "SlotRound"
    slotCorner.CornerRadius = UDim.new(1, 0)
    slotCorner.Parent = slot
    slot.BorderSizePixel = 0

    local equipped = slot:FindFirstChild("Equipped")
    if equipped then
        local children = equipped:GetChildren()
        
        -- 2. HAPUS/SEMBUNYIKAN outline 1, 2, 3 (garis kotak)
        for i = 1, #children do
            if i ~= 4 and children[i]:IsA("GuiObject") then
                children[i].Visible = false
                children[i].BackgroundTransparency = 1
            end
        end

        -- 3. MODIFIKASI CHILD [4]: Jadi Outline Bulat Sempurna
        local edge4 = children[4]
        if edge4 and edge4:IsA("GuiObject") then
            edge4.Visible = equipped.Visible
            edge4.Size = UDim2.new(1, 0, 1, 0) -- Full nutupin slot
            edge4.Position = UDim2.new(0, 0, 0, 0)
            edge4.BackgroundColor3 = Color3.new(1, 1, 1) -- Putih
            edge4.BackgroundTransparency = 0
            
            -- Kasih UIStroke di child [4] biar bentuknya garis lingkaran (bukan blok putih)
            local stroke = edge4:FindFirstChild("StrokeFix") or Instance.new("UIStroke")
            stroke.Name = "StrokeFix"
            stroke.Thickness = 2.5
            stroke.Color = Color3.new(1, 1, 1)
            stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            stroke.Parent = edge4
            
            -- Jadikan child [4] transparan tapi strokenya muncul
            edge4.BackgroundTransparency = 1 
            
            local edgeCorner = edge4:FindFirstChild("EdgeRound") or Instance.new("UICorner")
            edgeCorner.Name = "EdgeRound"
            edgeCorner.CornerRadius = UDim.new(1, 0)
            edgeCorner.Parent = edge4
        end

        -- 4. LOGIKA VISIBLE HOTBAR (Hitam pas pegang, Transparan pas lepas)
        if isHotbar then
            if equipped.Visible then
                slot.BackgroundTransparency = 0
                slot.BackgroundColor3 = Color3.new(0, 0, 0)
            else
                slot.BackgroundTransparency = 1
            end
        end
    end
end

RunService.RenderStepped:Connect(function()
    -- Eksekusi Hotbar & Inventory 1-99
    for i = 1, 99 do
        local id = tostring(i)
        FixSelectionEdge(Hotbar:FindFirstChild(id), true)
        FixSelectionEdge(InvGrid:FindFirstChild(id), false)
    end

    -- Fix SearchBox (Melengkung, Teks Kecil, Presisi)
    if SearchBox then
        local sCorner = SearchBox:FindFirstChild("Round") or Instance.new("UICorner")
        sCorner.Name = "Round"
        sCorner.CornerRadius = UDim.new(0, 10)
        sCorner.Parent = SearchBox
        
        SearchBox.TextSize = 14
        SearchBox.TextXAlignment = Enum.TextXAlignment.Left
        SearchBox.BorderSizePixel = 0
        
        local pad = SearchBox:FindFirstChild("Pad") or Instance.new("UIPadding")
        pad.Name = "Pad"
        pad.PaddingLeft = UDim.new(0, 12)
        pad.Parent = SearchBox
        
        -- SearchBox pojokan jangan lancip
        local sFrame = SearchBox.Parent
