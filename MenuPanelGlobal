local opened = false
local animating = false

--// TITIK KOORDINAT & SIZE ANIMASI
local sizeNormal = UDim2.new(0, 44, 0, 44)
local sizeKecil = UDim2.new(0, 32, 0, 32)
local posAwal = UDim2.new(0.5, -22, 0, 12)
local posBawah = UDim2.new(0.5, -16, 0, 65) -- Offset disesuaikan untuk size 32
local posKanan = UDim2.new(0.5, 150, 0, 65)

local function toggleMenu(state)
    if animating then return end
    animating = true
    opened = state

    local shrinkInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    local shrinkTween = TweenService:Create(mainIcon, shrinkInfo, {Size = UDim2.new(0, 0, 0, 0), Rotation = 180})
    shrinkTween:Play()

    if opened then
        -- 1. Tombol mengecil sambil turun
        TweenService:Create(toggleButton, TweenInfo.new(0.2, Enum.EasingStyle.Sine), {Position = posBawah, Size = sizeKecil}):Play()
        task.wait(0.2)
        
        -- 2. Tombol geser ke kanan
        TweenService:Create(toggleButton, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = posKanan}):Play()
        task.wait(0.3)

        mainIcon.Image = CLOSE_ICON_ID
        mainIcon.Rotation = -180
        
        mainFrame.Position = UDim2.new(0.5, 145, 0, 81) 
        mainFrame.Size = UDim2.new(0, 0, 0, 60)
        mainFrame.Visible = true

        TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, 300, 0, 60)}):Play()
    else
        local tweenClose = TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 60)})
        tweenClose:Play()
        tweenClose.Completed:Wait()
        mainFrame.Visible = false

        mainIcon.Image = MENU_ICON_ID
        mainIcon.Rotation = -180

        -- 2. Tombol balik ke tengah
        TweenService:Create(toggleButton, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = posBawah}):Play()
        task.wait(0.3)

        -- 3. Tombol membesar ke posisi semula
        TweenService:Create(toggleButton, TweenInfo.new(0.2, Enum.EasingStyle.Sine), {Position = posAwal, Size = sizeNormal}):Play()
        task.wait(0.2)
    end

    local growTween = TweenService:Create(mainIcon, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0.85, 0, 0.85, 0), Rotation = 0})
    growTween:Play()
    task.wait(0.3)
    animating = false
end

toggleButton.MouseButton1Click:Connect(function() toggleMenu(not opened) end)

--// CLOSE DETECTOR (Camera Friendly)
UserInputService.InputBegan:Connect(function(input, processed)
    if not opened or animating or processed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        toggleMenu(false)
    end
end)

local validUINames = {}
for _, item in ipairs(menuItems) do validUINames[item.Text.."UI"] = true end

for i, item in ipairs(menuItems) do
    local btn = Instance.new("ImageButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
    btn.BackgroundTransparency = 0.7
    btn.Image = item.Icon
    btn.ScaleType = Enum.ScaleType.Fit
    btn.ZIndex = 9998
    btn.Parent = scroll
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0,8)
    corner.Parent = btn

    local indicator = Instance.new("ImageLabel")
    indicator.Name = "WarningIndicator"
    indicator.Size = UDim2.new(0, 18, 0, 18)
    indicator.Position = UDim2.new(1, 2, 1, 2)
    indicator.AnchorPoint = Vector2.new(1, 1)
    indicator.BackgroundTransparency = 1
    indicator.Image = WARNING_ICON_ID
    indicator.ZIndex = 10005 
    indicator.Visible = false
    indicator.Parent = btn

    task.spawn(function()
        while task.wait(1) do
            local uiName = item.Text.."UI"
            local targetUI = PlayerGui:FindFirstChild(uiName) or CoreGui:FindFirstChild(uiName)
            indicator.Visible = (targetUI == nil)
        end
    end)

    btn.MouseButton1Click:Connect(function()
        local uiName = item.Text.."UI"
        local targetUI = PlayerGui:FindFirstChild(uiName) or CoreGui:FindFirstChild(uiName)
        
        for _, v in pairs(PlayerGui:GetChildren()) do 
            if v:IsA("ScreenGui") and validUINames[v.Name] and v.Name ~= uiName then v.Enabled = false end 
        end
        for _, v in pairs(CoreGui:GetChildren()) do 
            if v:IsA("ScreenGui") and validUINames[v.Name] and v.Name ~= uiName then v.Enabled = false end 
        end

        if targetUI then targetUI.Enabled = not targetUI.Enabled end
        toggleMenu(false)
    end)
end

